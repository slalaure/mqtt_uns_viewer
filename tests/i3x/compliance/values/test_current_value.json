[
  {
    "id": "test-cv-001",
    "name": "Get current value returns valid response",
    "description": "RFC 4.2.1.1 - LastKnownValue query MUST return the current value",
    "category": "values",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/value"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.elementId", "exists": true},
      {"type": "jsonPath", "path": "$.value", "exists": true}
    ]
  },
  {
    "id": "test-cv-002",
    "name": "Get current value includes elementId",
    "description": "RFC 4.2.1.1 - Response MUST include the requested elementId",
    "category": "values",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/value"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.elementId", "value": "CNC-001"}
    ]
  },
  {
    "id": "test-cv-003",
    "name": "Get current value includes isComposition",
    "description": "RFC 4.2.1.1 - Response MUST include isComposition for client awareness",
    "category": "values",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/value"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.isComposition", "exists": true},
      {"type": "jsonPath", "path": "$.isComposition", "valueType": "boolean"}
    ]
  },
  {
    "id": "test-cv-004",
    "name": "Get current value accepts maxDepth parameter",
    "description": "RFC 4.2.1.1 - Query MUST support maxDepth parameter",
    "category": "values",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/value",
      "query": {"maxDepth": "1"}
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.value", "exists": true}
    ]
  },
  {
    "id": "test-cv-005",
    "name": "Get current value returns 404 for unknown ID",
    "description": "RFC 4.2.1.1 - Unknown ElementId should return 404",
    "category": "values",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/NonExistentObject12345/value"
    },
    "assertions": [
      {"type": "status", "value": 404}
    ]
  }
]
