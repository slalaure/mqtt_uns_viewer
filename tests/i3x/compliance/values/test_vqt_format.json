[
  {
    "id": "test-vqt-001",
    "name": "Value response contains VQT structure",
    "description": "RFC 4.2.1.1 - Response MUST include Value-Quality-Timestamp structure",
    "category": "values",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/value"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.value", "exists": true}
    ]
  },
  {
    "id": "test-vqt-002",
    "name": "VQT value field exists",
    "description": "RFC 4.2.1.1 - VQT structure MUST include value field",
    "category": "values",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/value"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.value.value", "exists": true}
    ]
  },
  {
    "id": "test-vqt-003",
    "name": "VQT quality field exists",
    "description": "RFC 4.2.1.1 - VQT structure MUST include quality field",
    "category": "values",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/value"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.value.quality", "exists": true},
      {"type": "jsonPath", "path": "$.value.quality", "valueType": "string"}
    ]
  },
  {
    "id": "test-vqt-004",
    "name": "VQT timestamp field exists",
    "description": "RFC 4.2.1.1 - VQT structure MUST include timestamp field (RFC 3339 format)",
    "category": "values",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/value"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.value.timestamp", "exists": true},
      {"type": "jsonPath", "path": "$.value.timestamp", "valueType": "string"}
    ]
  },
  {
    "id": "test-vqt-005",
    "name": "VQT quality is valid value",
    "description": "RFC 4.2.1.1 - Quality MUST be Good, GoodNoData, Bad, or Uncertain",
    "category": "values",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/value"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.value.quality", "matches": "^(Good|GoodNoData|Bad|Uncertain)$"}
    ]
  }
]
