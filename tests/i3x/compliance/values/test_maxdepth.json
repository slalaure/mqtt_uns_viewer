[
  {
    "id": "test-md-001",
    "name": "maxDepth=1 returns single element value",
    "description": "RFC 4.2.1.1 - maxDepth=1 means no recursion (just this element's value)",
    "category": "values",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/value",
      "query": {"maxDepth": "1"}
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.elementId", "exists": true},
      {"type": "jsonPath", "path": "$.value", "exists": true}
    ]
  },
  {
    "id": "test-md-002",
    "name": "maxDepth=0 accepted for infinite recursion",
    "description": "RFC 4.2.1.1 - maxDepth=0 means infinite recursion through HasComponent",
    "category": "values",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/value",
      "query": {"maxDepth": "0"}
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.value", "exists": true}
    ]
  },
  {
    "id": "test-md-003",
    "name": "maxDepth=2 accepted for limited recursion",
    "description": "RFC 4.2.1.1 - maxDepth=N recurses up to N levels deep",
    "category": "values",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/value",
      "query": {"maxDepth": "2"}
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.value", "exists": true}
    ]
  },
  {
    "id": "test-md-004",
    "name": "Default maxDepth is 1 (no recursion)",
    "description": "RFC 4.2.1.1 - Default maxDepth SHOULD be 1",
    "category": "values",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/value"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.value", "exists": true}
    ]
  },
  {
    "id": "test-md-005",
    "name": "Composition element returns nested structure with maxDepth > 1",
    "description": "RFC 4.2.1.1 - When recursing, response includes element's own value under _value key with children keyed by elementId",
    "category": "values",
    "required": false,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/value",
      "query": {"maxDepth": "2"}
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.value", "exists": true},
      {"type": "jsonPath", "path": "$.isComposition", "exists": true}
    ]
  }
]
