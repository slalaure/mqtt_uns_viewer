[
  {
    "id": "test-hv-001",
    "name": "Get historical values returns array",
    "description": "RFC 4.2.1.2 - HistoricalValue query MUST return an array of historical values",
    "category": "values",
    "required": false,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/history"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "isArray": true}
    ]
  },
  {
    "id": "test-hv-002",
    "name": "Historical values contain VQT structure",
    "description": "RFC 4.2.1.2 - Each element MUST include Value-Quality-Timestamp structure",
    "category": "values",
    "required": false,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/history"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "minLength": 1},
      {"type": "jsonPath", "path": "$[0].value", "exists": true},
      {"type": "jsonPath", "path": "$[0].quality", "exists": true},
      {"type": "jsonPath", "path": "$[0].timestamp", "exists": true}
    ]
  },
  {
    "id": "test-hv-003",
    "name": "Historical values support startTime filter",
    "description": "RFC 4.2.1.2 - Query MAY filter by startTime",
    "category": "values",
    "required": false,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/history",
      "query": {"startTime": "2024-01-01T00:00:00Z"}
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "isArray": true}
    ]
  },
  {
    "id": "test-hv-004",
    "name": "Historical values support endTime filter",
    "description": "RFC 4.2.1.2 - Query MAY filter by endTime",
    "category": "values",
    "required": false,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/history",
      "query": {"endTime": "2030-12-31T23:59:59Z"}
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "isArray": true}
    ]
  },
  {
    "id": "test-hv-005",
    "name": "Historical values support time range filter",
    "description": "RFC 4.2.1.2 - Query MAY filter by both startTime and endTime",
    "category": "values",
    "required": false,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/history",
      "query": {
        "startTime": "2024-01-01T00:00:00Z",
        "endTime": "2030-12-31T23:59:59Z"
      }
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "isArray": true}
    ]
  },
  {
    "id": "test-hv-006",
    "name": "Historical values support maxDepth parameter",
    "description": "RFC 4.2.1.2 - Query MUST support maxDepth parameter",
    "category": "values",
    "required": false,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/history",
      "query": {"maxDepth": "1"}
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "isArray": true}
    ]
  },
  {
    "id": "test-hv-007",
    "name": "Historical values returns 404 for unknown ID",
    "description": "RFC 4.2.1.2 - Unknown ElementId should return 404",
    "category": "values",
    "required": false,
    "request": {
      "method": "GET",
      "path": "/objects/NonExistentObject12345/history"
    },
    "assertions": [
      {"type": "status", "value": 404}
    ]
  }
]
