[
  {
    "id": "test-inst-001",
    "name": "Get objects returns valid list",
    "description": "RFC 4.1.5 - Instances query MUST return an array of instance objects",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "isArray": true}
    ]
  },
  {
    "id": "test-inst-002",
    "name": "Objects have required elementId field",
    "description": "RFC 3.1.1 - Required metadata: ElementId",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "minLength": 1},
      {"type": "jsonPath", "path": "$[0].elementId", "exists": true},
      {"type": "jsonPath", "path": "$[0].elementId", "valueType": "string"}
    ]
  },
  {
    "id": "test-inst-003",
    "name": "Objects have required displayName field",
    "description": "RFC 3.1.1 - Required metadata: DisplayName",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$[0].displayName", "exists": true},
      {"type": "jsonPath", "path": "$[0].displayName", "valueType": "string"}
    ]
  },
  {
    "id": "test-inst-004",
    "name": "Objects have required typeId field",
    "description": "RFC 3.1.1 - Objects MUST reference their Object Type",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$[0].typeId", "exists": true},
      {"type": "jsonPath", "path": "$[0].typeId", "valueType": "string"}
    ]
  },
  {
    "id": "test-inst-005",
    "name": "Objects have required namespaceUri field",
    "description": "RFC 3.1.1 - Required metadata: NamespaceURI",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$[0].namespaceUri", "exists": true},
      {"type": "jsonPath", "path": "$[0].namespaceUri", "valueType": "string"}
    ]
  },
  {
    "id": "test-inst-006",
    "name": "Objects have required isComposition field",
    "description": "RFC 3.1.1 - Required metadata: HasChildren/isComposition",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$[0].isComposition", "exists": true},
      {"type": "jsonPath", "path": "$[0].isComposition", "valueType": "boolean"}
    ]
  },
  {
    "id": "test-inst-007",
    "name": "Objects can be filtered by typeId",
    "description": "RFC 4.1.5 - Instances MAY be filtered by Type ElementId",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects",
      "query": {"sourceTypeId": "MachineType"}
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "isArray": true}
    ]
  },
  {
    "id": "test-inst-008",
    "name": "Get object by ID returns valid object",
    "description": "RFC 4.1.7 - Object definition query MUST return the instance object for the requested ElementId",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.elementId", "exists": true},
      {"type": "jsonPath", "path": "$.displayName", "exists": true},
      {"type": "jsonPath", "path": "$.typeId", "exists": true},
      {"type": "jsonPath", "path": "$.namespaceUri", "exists": true},
      {"type": "jsonPath", "path": "$.isComposition", "exists": true}
    ]
  },
  {
    "id": "test-inst-009",
    "name": "Get object by ID returns 404 for unknown ID",
    "description": "RFC 4.1.7 - Unknown ElementId should return 404",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/NonExistentObject12345"
    },
    "assertions": [
      {"type": "status", "value": 404}
    ]
  },
  {
    "id": "test-inst-010",
    "name": "Get related objects returns array",
    "description": "RFC 4.1.6 - Related objects query MUST return an array of objects",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/related"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "isArray": true}
    ]
  },
  {
    "id": "test-inst-011",
    "name": "Get related objects can filter by relationship type",
    "description": "RFC 4.1.6 - Related objects query MAY filter by relationship type",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/CNC-001/related",
      "query": {"relationshiptype": "HasChildren"}
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "isArray": true}
    ]
  },
  {
    "id": "test-inst-012",
    "name": "Get related objects returns 404 for unknown source ID",
    "description": "RFC 4.1.6 - Unknown source ElementId should return 404",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objects/NonExistentObject12345/related"
    },
    "assertions": [
      {"type": "status", "value": 404}
    ]
  }
]
