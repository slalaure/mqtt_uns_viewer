[
  {
    "id": "test-ns-001",
    "name": "Get namespaces returns valid list",
    "description": "RFC 4.1.1 - Namespaces query MUST return an array of Namespaces",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/namespaces"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "isArray": true}
    ]
  },
  {
    "id": "test-ns-002",
    "name": "Namespaces have required uri field",
    "description": "RFC 4.1.1 - All Namespaces MUST have a Namespace URI",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/namespaces"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "minLength": 1},
      {"type": "jsonPath", "path": "$[0].uri", "exists": true},
      {"type": "jsonPath", "path": "$[0].uri", "valueType": "string"}
    ]
  },
  {
    "id": "test-ns-003",
    "name": "Namespaces have required displayName field",
    "description": "RFC 4.1.1 - All Namespaces MUST have a displayName",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/namespaces"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "minLength": 1},
      {"type": "jsonPath", "path": "$[0].displayName", "exists": true},
      {"type": "jsonPath", "path": "$[0].displayName", "valueType": "string"}
    ]
  }
]
