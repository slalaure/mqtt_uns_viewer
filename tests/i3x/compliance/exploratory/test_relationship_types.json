[
  {
    "id": "test-rt-001",
    "name": "Get relationship types returns valid list",
    "description": "RFC 4.1.4 - Relationship Types query MUST return an array of relationship type definitions",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/relationshiptypes"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "isArray": true}
    ]
  },
  {
    "id": "test-rt-002",
    "name": "Relationship types have required elementId field",
    "description": "RFC 4.1.4 - Each relationship type MUST include elementId",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/relationshiptypes"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "minLength": 1},
      {"type": "jsonPath", "path": "$[0].elementId", "exists": true},
      {"type": "jsonPath", "path": "$[0].elementId", "valueType": "string"}
    ]
  },
  {
    "id": "test-rt-003",
    "name": "Relationship types have required displayName field",
    "description": "RFC 4.1.4 - Each relationship type MUST include displayName",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/relationshiptypes"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$[0].displayName", "exists": true},
      {"type": "jsonPath", "path": "$[0].displayName", "valueType": "string"}
    ]
  },
  {
    "id": "test-rt-004",
    "name": "Relationship types have required namespaceUri field",
    "description": "RFC 4.1.4 - Each relationship type MUST include namespaceUri",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/relationshiptypes"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$[0].namespaceUri", "exists": true},
      {"type": "jsonPath", "path": "$[0].namespaceUri", "valueType": "string"}
    ]
  },
  {
    "id": "test-rt-005",
    "name": "Relationship types have required reverseOf field",
    "description": "RFC 4.1.4 - Each relationship type MUST include reverseOf",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/relationshiptypes"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$[0].reverseOf", "exists": true},
      {"type": "jsonPath", "path": "$[0].reverseOf", "valueType": "string"}
    ]
  },
  {
    "id": "test-rt-006",
    "name": "HasParent relationship type exists",
    "description": "RFC 4.1.4 - Implementations MUST support HasParent organizational relationship",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/relationshiptypes/HasParent"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.elementId", "value": "HasParent"},
      {"type": "jsonPath", "path": "$.reverseOf", "value": "HasChildren"}
    ]
  },
  {
    "id": "test-rt-007",
    "name": "HasChildren relationship type exists",
    "description": "RFC 4.1.4 - Implementations MUST support HasChildren organizational relationship",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/relationshiptypes/HasChildren"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.elementId", "value": "HasChildren"},
      {"type": "jsonPath", "path": "$.reverseOf", "value": "HasParent"}
    ]
  },
  {
    "id": "test-rt-008",
    "name": "HasComponent relationship type exists (if composition supported)",
    "description": "RFC 4.1.4 - If composition is supported, HasComponent MUST be available",
    "category": "exploratory",
    "required": false,
    "request": {
      "method": "GET",
      "path": "/relationshiptypes/HasComponent"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.elementId", "value": "HasComponent"},
      {"type": "jsonPath", "path": "$.reverseOf", "value": "ComponentOf"}
    ]
  },
  {
    "id": "test-rt-009",
    "name": "Get relationship type by ID returns 404 for unknown ID",
    "description": "RFC 4.1.4 - Unknown ElementId should return 404",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/relationshiptypes/NonExistentRelType12345"
    },
    "assertions": [
      {"type": "status", "value": 404}
    ]
  }
]
