[
  {
    "id": "test-ot-001",
    "name": "Get object types returns valid list",
    "description": "RFC 4.1.3 - Object Types query MUST return an array of Type definitions",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objecttypes"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "isArray": true}
    ]
  },
  {
    "id": "test-ot-002",
    "name": "Object types have required elementId field",
    "description": "RFC 4.1.3 - All Types MUST have an ElementId",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objecttypes"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "minLength": 1},
      {"type": "jsonPath", "path": "$[0].elementId", "exists": true},
      {"type": "jsonPath", "path": "$[0].elementId", "valueType": "string"}
    ]
  },
  {
    "id": "test-ot-003",
    "name": "Object types have required displayName field",
    "description": "RFC 4.1.3 - All Types MUST have a displayName",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objecttypes"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$[0].displayName", "exists": true},
      {"type": "jsonPath", "path": "$[0].displayName", "valueType": "string"}
    ]
  },
  {
    "id": "test-ot-004",
    "name": "Object types have required namespaceUri field",
    "description": "RFC 4.1.3 - All Types MUST have a namespaceUri",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objecttypes"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$[0].namespaceUri", "exists": true},
      {"type": "jsonPath", "path": "$[0].namespaceUri", "valueType": "string"}
    ]
  },
  {
    "id": "test-ot-005",
    "name": "Object types have required schema field",
    "description": "RFC 4.1.3 - All Types MUST have a schema definition",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objecttypes"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$[0].schema", "exists": true},
      {"type": "jsonPath", "path": "$[0].schema", "valueType": "object"}
    ]
  },
  {
    "id": "test-ot-006",
    "name": "Object types can be filtered by namespace",
    "description": "RFC 4.1.3 - Types MAY be filtered by NamespaceURI",
    "category": "exploratory",
    "required": false,
    "request": {
      "method": "GET",
      "path": "/objecttypes",
      "query": {"namespaceUri": "https://www.abelara.com/ns/equipment"}
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "isArray": true}
    ]
  },
  {
    "id": "test-ot-007",
    "name": "Get object type by ID returns valid type",
    "description": "RFC 4.1.2 - Object Type definition query MUST return the Type for the requested ElementId",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objecttypes/MachineType"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.elementId", "exists": true},
      {"type": "jsonPath", "path": "$.displayName", "exists": true},
      {"type": "jsonPath", "path": "$.namespaceUri", "exists": true},
      {"type": "jsonPath", "path": "$.schema", "exists": true}
    ]
  },
  {
    "id": "test-ot-008",
    "name": "Get object type by ID returns 404 for unknown ID",
    "description": "RFC 4.1.2 - Unknown ElementId should return 404",
    "category": "exploratory",
    "required": true,
    "request": {
      "method": "GET",
      "path": "/objecttypes/NonExistentType12345"
    },
    "assertions": [
      {"type": "status", "value": 404}
    ]
  }
]
