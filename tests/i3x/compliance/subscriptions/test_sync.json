[
  {
    "id": "test-sync-001",
    "name": "Sync endpoint returns array",
    "description": "RFC 4.2.3.4 - Sync MUST respond with an array of updates",
    "category": "subscriptions",
    "required": false,
    "setup": [
      {
        "method": "POST",
        "path": "/subscriptions",
        "body": {},
        "save": {"subscriptionId": "$.subscriptionId"}
      },
      {
        "method": "POST",
        "path": "/subscriptions/${subscriptionId}/register",
        "body": {
          "elementIds": ["CNC-001"],
          "maxDepth": 1
        }
      }
    ],
    "request": {
      "method": "POST",
      "path": "/subscriptions/${subscriptionId}/sync"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "isArray": true}
    ],
    "cleanup": [
      {
        "method": "DELETE",
        "path": "/subscriptions/${subscriptionId}"
      }
    ]
  },
  {
    "id": "test-sync-002",
    "name": "Sync clears queue on retrieval",
    "description": "RFC 4.2.3.4 - Calling sync acknowledges and clears previous updates",
