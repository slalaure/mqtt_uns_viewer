    "required": false,
    "setup": [
      {
        "method": "POST",
        "path": "/subscriptions",
        "body": {},
        "save": {"subscriptionId": "$.subscriptionId"}
      },
      {
        "method": "POST",
        "path": "/subscriptions/${subscriptionId}/register",
        "body": {
          "elementIds": ["CNC-001"],
          "maxDepth": 1
        }
      },
      {
        "method": "POST",
        "path": "/subscriptions/${subscriptionId}/sync"
      }
    ],
    "request": {
      "method": "POST",
      "path": "/subscriptions/${subscriptionId}/sync"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$", "isArray": true}
    ],
    "cleanup": [
      {
        "method": "DELETE",
        "path": "/subscriptions/${subscriptionId}"
      }
    ]
  },
  {
    "id": "test-sync-003",
    "name": "Sync for non-existent subscription returns 404",
    "description": "RFC 4.2.3.4 - Non-existent subscription should return 404",
    "category": "subscriptions",
    "required": false,
    "request": {
      "method": "POST",
      "path": "/subscriptions/nonexistent12345/sync"
    },
    "assertions": [
      {"type": "status", "value": 404}
    ]
  },
