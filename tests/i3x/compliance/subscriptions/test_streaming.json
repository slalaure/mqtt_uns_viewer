[
  {
    "id": "test-streaming-001",
    "name": "SSE stream endpoint exists",
    "description": "RFC 4.2.3.2 (streaming) - Server MUST support SSE streaming endpoint",
    "category": "subscriptions",
    "required": false,
    "setup": [
      {
        "method": "POST",
        "path": "/subscriptions",
        "body": {},
        "save": {"subscriptionId": "$.subscriptionId"}
      },
      {
        "method": "POST",
        "path": "/subscriptions/${subscriptionId}/register",
        "body": {
          "elementIds": ["CNC-001"],
          "maxDepth": 1
        }
      }
    ],
    "request": {
      "method": "GET",
      "path": "/subscriptions/${subscriptionId}/stream"
    },
    "assertions": [
      {"type": "status", "value": 200}
    ],
    "cleanup": [
      {
        "method": "DELETE",
        "path": "/subscriptions/${subscriptionId}"
      }
    ]
  },
  {
    "id": "test-streaming-002",
    "name": "SSE stream for non-existent subscription returns 404",
    "description": "RFC 4.2.3.2 - Non-existent subscription should return 404",
    "category": "subscriptions",
    "required": false,
    "request": {
      "method": "GET",
      "path": "/subscriptions/nonexistent12345/stream"
    },
    "assertions": [
      {"type": "status", "value": 404}
    ]
  },
  {
    "id": "test-streaming-003",
    "name": "SSE stream clears pending queue",
    "description": "RFC 4.2.3.2 (streaming) - When streaming starts, pending queue should be cleared",
    "category": "subscriptions",
    "required": false,
    "setup": [
      {
        "method": "POST",
        "path": "/subscriptions",
        "body": {},
        "save": {"subscriptionId": "$.subscriptionId"}
      },
      {
        "method": "POST",
        "path": "/subscriptions/${subscriptionId}/register",
        "body": {
          "elementIds": ["CNC-001"],
          "maxDepth": 1
        }
      }
    ],
    "request": {
      "method": "GET",
      "path": "/subscriptions/${subscriptionId}"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.subscriptionId", "exists": true}
    ],
    "cleanup": [
      {
        "method": "DELETE",
        "path": "/subscriptions/${subscriptionId}"
      }
    ]
  }
]
