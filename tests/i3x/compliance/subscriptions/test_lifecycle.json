[
  {
    "id": "test-sub-001",
    "name": "Create subscription returns subscriptionId",
    "description": "RFC 4.2.3.1 - Create subscription response MUST include a Subscription Id",
    "category": "subscriptions",
    "required": false,
    "request": {
      "method": "POST",
      "path": "/subscriptions",
      "body": {}
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.subscriptionId", "exists": true}
    ]
  },
  {
    "id": "test-sub-002",
    "name": "Create subscription returns success message",
    "description": "RFC 4.2.3.1 - Create subscription response should include a message",
    "category": "subscriptions",
    "required": false,
    "request": {
      "method": "POST",
      "path": "/subscriptions",
      "body": {}
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.message", "exists": true},
      {"type": "jsonPath", "path": "$.message", "valueType": "string"}
    ]
  },
  {
    "id": "test-sub-003",
    "name": "Register monitored items succeeds",
    "description": "RFC 4.2.3.2 - Register monitored items for a subscription",
    "category": "subscriptions",
    "required": false,
    "setup": [
      {
        "method": "POST",
        "path": "/subscriptions",
        "body": {},
        "save": {"subscriptionId": "$.subscriptionId"}
      }
    ],
    "request": {
      "method": "POST",
      "path": "/subscriptions/${subscriptionId}/register",
      "body": {
        "elementIds": ["CNC-001"],
        "maxDepth": 1
      }
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.message", "exists": true}
    ],
    "cleanup": [
      {
        "method": "DELETE",
        "path": "/subscriptions/${subscriptionId}"
      }
    ]
  },
  {
    "id": "test-sub-004",
    "name": "Register monitored items validates elementIds",
    "description": "RFC 4.2.3.2 - Invalid elementIds should return 404",
    "category": "subscriptions",
    "required": false,
    "setup": [
      {
        "method": "POST",
        "path": "/subscriptions",
        "body": {},
        "save": {"subscriptionId": "$.subscriptionId"}
      }
    ],
    "request": {
      "method": "POST",
      "path": "/subscriptions/${subscriptionId}/register",
      "body": {
        "elementIds": ["NonExistentElement12345"],
        "maxDepth": 1
      }
    },
    "assertions": [
      {"type": "status", "value": 404}
    ],
    "cleanup": [
      {
        "method": "DELETE",
        "path": "/subscriptions/${subscriptionId}"
      }
    ]
  },
  {
    "id": "test-sub-005",
    "name": "Unregister monitored items succeeds",
    "description": "RFC 4.2.3.3 - Remove monitored items from a subscription",
    "category": "subscriptions",
    "required": false,
    "setup": [
      {
        "method": "POST",
        "path": "/subscriptions",
        "body": {},
        "save": {"subscriptionId": "$.subscriptionId"}
      },
      {
        "method": "POST",
        "path": "/subscriptions/${subscriptionId}/register",
        "body": {
          "elementIds": ["CNC-001"],
          "maxDepth": 1
        }
      }
    ],
    "request": {
      "method": "POST",
      "path": "/subscriptions/${subscriptionId}/unregister",
      "body": {
        "elementIds": ["CNC-001"],
        "maxDepth": 1
      }
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.message", "exists": true}
    ],
    "cleanup": [
      {
        "method": "DELETE",
        "path": "/subscriptions/${subscriptionId}"
      }
    ]
  },
  {
    "id": "test-sub-006",
    "name": "Delete subscription succeeds",
    "description": "RFC 4.2.3.5 - Unsubscribe MUST cancel publication and release resources",
    "category": "subscriptions",
    "required": false,
    "setup": [
      {
        "method": "POST",
        "path": "/subscriptions",
        "body": {},
        "save": {"subscriptionId": "$.subscriptionId"}
      }
    ],
    "request": {
      "method": "DELETE",
      "path": "/subscriptions/${subscriptionId}"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.message", "exists": true}
    ]
  },
  {
    "id": "test-sub-007",
    "name": "Get subscription details succeeds",
    "description": "Get subscription returns current state and monitored items",
    "category": "subscriptions",
    "required": false,
    "setup": [
      {
        "method": "POST",
        "path": "/subscriptions",
        "body": {},
        "save": {"subscriptionId": "$.subscriptionId"}
      }
    ],
    "request": {
      "method": "GET",
      "path": "/subscriptions/${subscriptionId}"
    },
    "assertions": [
      {"type": "status", "value": 200},
      {"type": "jsonPath", "path": "$.subscriptionId", "exists": true},
      {"type": "jsonPath", "path": "$.created", "exists": true}
    ],
    "cleanup": [
      {
        "method": "DELETE",
        "path": "/subscriptions/${subscriptionId}"
      }
    ]
  },
  {
    "id": "test-sub-008",
    "name": "Register to non-existent subscription returns 404",
    "description": "RFC 4.2.3.2 - Non-existent subscription should return 404",
    "category": "subscriptions",
    "required": false,
    "request": {
      "method": "POST",
      "path": "/subscriptions/nonexistent12345/register",
      "body": {
        "elementIds": ["CNC-001"],
        "maxDepth": 1
      }
    },
    "assertions": [
      {"type": "status", "value": 404}
    ]
  },
  {
    "id": "test-sub-009",
    "name": "Delete non-existent subscription returns appropriate response",
    "description": "RFC 4.2.3.5 - Deleting non-existent subscription should be handled gracefully",
    "category": "subscriptions",
    "required": false,
    "request": {
      "method": "DELETE",
      "path": "/subscriptions/nonexistent12345"
    },
    "assertions": [
      {"type": "status", "value": 200}
    ]
  }
]
